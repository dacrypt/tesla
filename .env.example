# Tesla CLI — Docker Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ──────────────────────────────────────────────────
TESLA_VIN=              # Your Tesla VIN (17 characters)
TESLA_RN=               # Order reservation number (e.g. RNXXXXXXXXX)

# ── API Server ────────────────────────────────────────────────
TESLA_PORT=8080         # Dashboard + API port

# ── Full Stack (docker-compose.full.yml) ──────────────────────
DB_PASSWORD=teslamate   # PostgreSQL password
ENCRYPTION_KEY=changeme # TeslaMate encryption key (generate a random string)
TM_PORT=4000            # TeslaMate web UI port
GRAFANA_PORT=3000       # Grafana dashboard port
GRAFANA_PASSWORD=admin  # Grafana admin password
MQTT_PORT=1883          # Mosquitto MQTT port
